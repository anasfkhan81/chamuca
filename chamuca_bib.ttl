#################################################################
# Bibliographic sources
#################################################################

bib:dalgado1913
    a bibo:Book ;
    dct:title "Influência Do Vocabulário Português Em Línguas Asiáticas" ;
    dct:creator bib:dalgado-sebastiao-rodolfo ;
    dct:publisher bib:imprensa-universidade-coimbra ;
    dct:issued "1913"^^xsd:gYear ;
    dct:language "pt" .

bib:dasa1965
    a bibo:Book ;
    dct:title "Hindi Sabdasagara. Navina samskarana" ;
    dct:creator bib:dasa ;
    dct:publisher bib:nagari-pracarini-sabha ;
    dct:issued "1965"^^xsd:gYear ;
    dct:language "hi" ;
    bibo:edition "2nd ed." .

bib:fallon1879
    a bibo:Book ;
    dct:title "A New Hindustani-English Dictionary, with Illustrations from Hindustani Literature and Folk-Lore" ;
    dct:creator bib:fallon-s-w ;
    dct:publisher bib:trubner-and-co ;
    dct:issued "1879"^^xsd:gYear ;
    dct:language "en" .

bib:mcgregor
    a bibo:Book ;
    dct:title "The Oxford Hindi-English Dictionary" ;
    dct:creator bib:mcgregor-r-s ;
    dct:publisher bib:oxford-university-press ;
    dct:language "en" .

bib:qureshi1971
    a bibo:Book ;
    dct:title "Kitabistan’s 20th Century Standard Dictionary" ;
    dct:creator bib:qureshi-bashir-ahmad ;
    dct:publisher bib:kitabistan-pub-co ;
    dct:issued "1971"^^xsd:gYear ;
    dct:language "en" .

bib:soares1936
    a bibo:Book ;
    dct:title "Portuguese Vocables In Asiatic Languages: From the Portuguese Original of Sebastião Rodolfo Dalgado" ;
    dct:creator bib:soares-anthony-xavier ;
    dct:publisher bib:oriental-institute ;
    dct:issued "1936"^^xsd:gYear ;
    dct:language "en" ;
    dct:source bib:dalgado1913 .

bib:yule-burnell1903
    a bibo:Book ;
    dct:title "Hobson-Jobson: A Glossary of Colloquial Anglo-Indian Words and Phrases, and of Kindred Terms, Etymological, Historical, Geographical and Discursive" ;
    dct:creator bib:yule-henry, bib:burnell-a-c ;
    dct:contributor bib:crooke-william ;
    dct:issued "1903"^^xsd:gYear ;
    dct:spatial "London" ;
    dct:language "en" .
